# Copy to .env and adjust for your environment:  cp .env.example .env
#
# Settings are read from environment variables or a .env file in the current
# working directory (pydantic-settings). All aggregator services share the
# aggregator-common config, so the same .env works for every service.

# --- Required ---
# PostgreSQL connection URL. The value below matches the docker-compose.yml
# postgres service (user/password/db all "aggregator", on localhost:5432).
# A bare postgresql:// URL is auto-rewritten to the psycopg (v3) driver.
DATABASE_URL=postgresql://aggregator:aggregator@localhost:5432/aggregator

# --- Production / compose ---
# When running the full stack via docker-compose.prod.yml, set these vars.
# The postgres service is reached by its compose service name ("postgres"),
# not "localhost". IMPORTANT: DATABASE_URL credentials must match
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB — both default to
# "aggregator" and any mismatch will cause the migrate step to fail.
#
# POSTGRES_USER=aggregator
# POSTGRES_PASSWORD=aggregator
# POSTGRES_DB=aggregator
#
# DATABASE_URL (production — host=postgres, the compose service name):
# DATABASE_URL=postgresql://aggregator:aggregator@postgres:5432/aggregator
#
# LLM credentials (required by summarize-rank service):
# OPENAI_API_KEY=
#
# LLM model selection — there is one knob per LLM-calling service. Uncomment
# and set all three to switch models "across the board". summarize-rank
# already defaults to mini; clusterer and brief default to gpt-4.1, so set
# those two to gpt-4.1-mini to minimize cost (≈3.5–5x cheaper per token).
# (These are also listed under each service's section below.)
# LLM_MODEL=gpt-4.1-mini            # summarize-rank
# CLUSTERER_LLM_MODEL=gpt-4.1-mini  # clusterer (default: gpt-4.1)
# BRIEF_LLM_MODEL=gpt-4.1-mini      # brief (default: gpt-4.1)
#
# --- Deploy (Pi / GHCR) ---
# Docker image registry prefix used by docker-compose.prod.yml.
# IMAGE_PREFIX=ghcr.io/oscarrenalias/personal-aggregator
#
# Image tag to deploy. Defaults to "latest" (tracks the most recent build).
# Pin to a specific tag (e.g. v0.1.3) for repeatable / rollback deploys.
# APP_VERSION=latest

# --- Web exposure (docker-compose.prod.yml) ---
# WEB_BIND controls which host interface the UI is published on:
#   0.0.0.0   → reachable from any device on your home LAN (default)
#   127.0.0.1 → Pi-local only (e.g. when fronting it with Tailscale)
# WEB_BIND=0.0.0.0
# WEB_PORT=8000
# (WEB_HOST — the in-container bind — is fixed to 0.0.0.0 by the compose file
#  and should not be overridden; it is unrelated to LAN exposure.)

# --- Common (optional; defaults shown) ---
# CLAIM_LEASE_SECONDS=600
# LOG_LEVEL=INFO

# --- Web (optional; defaults shown) ---
# Number of articles per page in feed lists.
# WEB_PAGE_SIZE=50
# Minimum importance_score for the Important smart view.
# WEB_IMPORTANT_THRESHOLD=70
# Show numeric unread counts (true) or qualitative dot markers only (false).
# WEB_SHOW_UNREAD_COUNTS=false

# --- Retriever (optional; defaults shown) ---
# RETRIEVER_POLL_INTERVAL_SECONDS=60
# RETRIEVER_MAX_WORKERS=8
# RETRIEVER_HTTP_TIMEOUT_SECONDS=30
# RETRIEVER_MAX_FEED_BYTES=10485760
# RETRIEVER_USER_AGENT=personal-aggregator/0.1 (feed retriever)
# RETRIEVER_MAX_SOURCE_FAILURES=20
# RETRIEVER_BACKOFF_BASE_SECONDS=60
# RETRIEVER_BACKOFF_CAP_SECONDS=21600

# --- Processor (optional; defaults shown) ---
# PROCESSOR_POLL_INTERVAL_SECONDS=5
# PROCESSOR_MAX_WORKERS=4
# PROCESSOR_BATCH_SIZE=20
# PROCESSOR_HTTP_TIMEOUT_SECONDS=30
# PROCESSOR_MAX_PAGE_BYTES=5242880
# PROCESSOR_USER_AGENT=personal-aggregator/0.1 (processor)
# PROCESSOR_FEED_CONTENT_MIN_CHARS=1500
# PROCESSOR_MIN_CONTENT_CHARS=200
# PROCESSOR_MAX_RETRIES=3
# PROCESSOR_BACKOFF_BASE_SECONDS=30

# --- Summarize-rank (optional; defaults shown) ---
# LLM_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# LLM_MAX_INPUT_CHARS=6000
# LLM_MAX_OUTPUT_TOKENS=400
# LLM_TEMPERATURE=0.2
# LLM_TIMEOUT_SECONDS=60
# SUMMARIZE_RANK_POLL_INTERVAL_SECONDS=5
# SUMMARIZE_RANK_MAX_WORKERS=4
# SUMMARIZE_RANK_BATCH_SIZE=10
# SUMMARIZE_RANK_MAX_RETRIES=3
# SUMMARIZE_RANK_BACKOFF_BASE_SECONDS=30
# SUMMARIZE_RANK_MIN_CONTENT_CHARS=200

# --- MCP server (optional; defaults shown) ---
# MCP_HOST: in-container bind address. Fixed to 0.0.0.0 inside the container;
#   LAN/Tailscale exposure is controlled by MCP_BIND in docker-compose.prod.yml.
# MCP_HOST=0.0.0.0
# MCP_PORT=8765
# MCP_PATH=/mcp
# MCP_DEFAULT_LIMIT=20
# MCP_MAX_LIMIT=100

# Note: Alembic migrations auto-load the root .env via python-dotenv (find_dotenv
# walks up the tree), so DATABASE_URL does not need to be exported separately.
# Running services from the repo root also picks up this .env automatically.

# --- Clusterer (optional; defaults shown) ---
# Seconds between scheduler poll cycles.
# CLUSTERER_POLL_INTERVAL_SECONDS=60
# Hours of history scanned by the fast-path candidate selection.
# CLUSTERER_CANDIDATE_WINDOW_HOURS_FAST=48
# Days of history scanned by the slow-path candidate selection.
# CLUSTERER_CANDIDATE_WINDOW_DAYS_SLOW=7
# Maximum candidate threads evaluated per article per clustering run.
# CLUSTERER_MAX_CANDIDATE_THREADS=10
# Minimum entity overlap ratio to consider two articles related.
# CLUSTERER_ENTITY_OVERLAP_THRESHOLD=0.2
# Minimum topic overlap ratio to consider two articles related.
# CLUSTERER_TOPIC_OVERLAP_THRESHOLD=0.2
# Minimum FTS similarity score to consider two articles related.
# CLUSTERER_FTS_SIMILARITY_THRESHOLD=0.1
# LLM model used for cluster classification reasoning.
# CLUSTERER_LLM_MODEL=gpt-4.1
# Maximum output tokens for each LLM call.
# CLUSTERER_LLM_MAX_OUTPUT_TOKENS=512
# LLM sampling temperature (0 = deterministic).
# CLUSTERER_LLM_TEMPERATURE=0.0
# Timeout in seconds for LLM calls.
# CLUSTERER_LLM_TIMEOUT_SECONDS=30
# Work-claim lease duration for clusterer jobs in seconds.
# CLUSTERER_CLAIM_LEASE_SECONDS=600
# Days of inactivity before a thread transitions to dormant.
# CLUSTERER_DORMANT_AGE_DAYS=7
# Days of dormancy before a thread is archived.
# CLUSTERER_ARCHIVE_AGE_DAYS=30
# Maximum articles processed per clustering cycle.
# CLUSTERER_BATCH_SIZE=20
# Minimum token Jaccard similarity to treat two titles as near-duplicates.
# CLUSTERER_TITLE_JACCARD_THRESHOLD=0.7
# Minimum grade (0–100) for a single-source thread to surface on its own
# (multi-source clusters surface via critical mass regardless).
# CLUSTERER_SURFACE_MIN_GRADE=80
# Minimum distinct source count required to surface a thread.
# CLUSTERER_SURFACE_MIN_SOURCES=2
# Minimum article member count required to surface a thread.
# CLUSTERER_SURFACE_MIN_MEMBERS=3
# Minimum composite similarity score required to consider merging two threads.
# CLUSTERER_MERGE_SIMILARITY_FLOOR=0.35
# Maximum candidate thread pairs checked for merging per consolidation cycle.
# CLUSTERER_MAX_MERGE_CHECKS=20
# Maximum age in days for threads shown in the default thread view.
# CLUSTERER_THREAD_VIEW_MAX_AGE_DAYS=7
# Days to retain archived threads before permanent deletion.
# CLUSTERER_THREAD_RETENTION_DAYS=30
# JSON array of RSS section/category titles too generic to use as thread titles.
# CLUSTERER_SECTION_TITLE_BLOCKLIST=["top stories","home","homepage","latest","news","breaking news"]
# Minimum minutes between consolidation passes; explicit recluster bypasses this floor.
# CLUSTERER_CONSOLIDATION_MIN_INTERVAL_MINUTES=10
# Maximum candidate threads passed to the LLM classifier per article.
# CLUSTERER_MAX_CLASSIFIER_CANDIDATES=5
# Only re-evaluate thread pairs that changed since the last consolidation pass (incremental merge).
# Set false to always sweep all pairs.
# CLUSTERER_INCREMENTAL_MERGE=true
# Cache per-pair LLM merge verdicts in the thread_merge_verdicts table to skip redundant LLM calls.
# Set false to disable caching and always re-run the LLM for every candidate pair.
# CLUSTERER_MERGE_VERDICT_CACHE=true

# --- Brief (optional; defaults shown) ---
# LLM model used to generate the daily brief (can differ from the summarize-rank model).
# BRIEF_LLM_MODEL=gpt-4.1
# Maximum output tokens for each LLM call during brief generation.
# BRIEF_LLM_MAX_OUTPUT_TOKENS=4096
# LLM sampling temperature for brief generation.
# BRIEF_LLM_TEMPERATURE=0.3
# Timeout in seconds for LLM calls during brief generation.
# BRIEF_LLM_TIMEOUT_SECONDS=120
# Hour of the day (in BRIEF_TIMEZONE) at which the brief is generated.
# BRIEF_GENERATION_HOUR=6
# Timezone for the brief generation schedule (IANA tz name, e.g. Europe/London).
# BRIEF_TIMEZONE=UTC
# Hours of article history included in each brief.
# BRIEF_PERIOD_HOURS=24
# Maximum number of topic sections included in each brief.
# BRIEF_MAX_TOPICS=6
# Maximum number of articles fed to the LLM as candidates for the brief.
# BRIEF_MAX_CANDIDATE_ARTICLES=80
# Number of previous briefs included as continuity context.
# BRIEF_CONTINUITY_COUNT=3
# Maximum number of LLM tool calls allowed per brief generation run.
# BRIEF_TOOL_MAX_CALLS=12
# Days to retain completed briefs before they are pruned.
# BRIEF_RETENTION_DAYS=30
# Seconds between scheduler poll cycles.
# BRIEF_POLL_INTERVAL_SECONDS=60
# Work-claim lease duration for brief jobs in seconds.
# BRIEF_CLAIM_LEASE_SECONDS=600

# --- Janitor (optional; defaults shown) ---
# Days to retain articles before purging (unsaved articles not in a live thread).
# JANITOR_ARTICLE_RETENTION_DAYS=14
# Days to retain archived threads before permanent deletion.
# JANITOR_THREAD_RETENTION_DAYS=30
# Days to retain completed briefs before pruning.
# JANITOR_BRIEF_RETENTION_DAYS=30
# Days to retain LLM call telemetry rows before purging.
# JANITOR_LLM_TELEMETRY_RETENTION_DAYS=30
# Hour of day (in JANITOR_TIMEZONE) to run the daily retention sweep.
# JANITOR_RUN_HOUR=4
# Timezone for the retention sweep schedule (IANA tz name, e.g. Europe/London).
# JANITOR_TIMEZONE=UTC
# Seconds between scheduler poll cycles.
# JANITOR_POLL_INTERVAL_SECONDS=3600

# --- LLM telemetry (optional; defaults shown) ---
# Persist one row per LLM call to the llm_calls table for cost/usage monitoring.
# LLM_TELEMETRY_ENABLED=true
# Persist prompt preview and hash alongside each row (privacy-sensitive; off by default).
# LLM_TELEMETRY_CAPTURE_PROMPTS=false
# Langfuse integration — all three vars required; omit any to disable the Langfuse callback.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=
